{
  "name": "open-claude-cowork",
  "version": "1.0.0",
  "description": "AI cowork desktop app — Claude Agent SDK + Composio tool router",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently --names server,electron --prefix-colors blue,green \"npm run server\" \"cross-env NODE_ENV=development electron .\"",
    "server": "node server/index.js",
    "server:dev": "node --watch server/index.js",
    "review": "node scripts/code-improver.js",
    "test": "node --test \"server/**/*.test.js\"",
    "check:models": "node scripts/check-model-ids.js",
    "visualizer": "electron visualization/main.js",
    "setup": "bash setup.sh"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^42.0.0",
    "electron-reloader": "^1.2.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "claude",
    "ai",
    "electron",
    "composio",
    "cowork"
  ],
  "license": "MIT"
}
