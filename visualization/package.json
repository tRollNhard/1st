{
  "name": "smillee",
  "version": "1.0.0",
  "description": "Smillee - music-reactive rainbow character visualizer for Spotify + TikTok",
  "main": "main.js",
  "author": "Jason Clark",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "node launch.js",
    "server:dev": "vite --port 5173",
    "electron:dev": "node launch.js --dev",
    "dist": "vite build && electron-builder --win portable",
    "dist:installer": "vite build && electron-builder --win nsis"
  },
  "keywords": [
    "smillee",
    "visualizer",
    "spotify",
    "tiktok",
    "electron"
  ],
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "vite": "^5.4.0"
  },
  "build": {
    "appId": "com.jasonclark.smillee",
    "productName": "Smillee",
    "asar": true,
    "files": [
      "main.js",
      "index.html",
      "package.json",
      "src/**",
      "dist-web/**",
      "build/icon.ico",
      "!.electron-data/**",
      "!.chrome-profile/**",
      "!dist/**",
      "!node_modules/**"
    ],
    "compression": "maximum",
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "portable": {
      "artifactName": "Smillee-${version}-portable.exe"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Smillee"
    }
  }
}
