# ── Required ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
PEXELS_API_KEY=

# ── Social Platforms (setup wizard fills these in) ────────────────────────────
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:3456/oauth/youtube

LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=

TIKTOK_ACCESS_TOKEN=
TIKTOK_OPEN_ID=

INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
# Register at https://api.imgur.com/oauth2/addclient (Anonymous usage, no callback).
# Required only if you publish to Instagram — Graph API needs a public image URL.
IMGUR_CLIENT_ID=

# ── Optional ──────────────────────────────────────────────────────────────────
POST_HOUR=9
POST_MINUTE=0
